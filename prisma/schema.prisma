generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id       Int        @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category?  @relation("SubCategories", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("SubCategories")
  products Product[]

  // The same name may exist under different parents (e.g. "Sponges"
  // under both "Dishwashing" and "Cleaning Tools").
  @@unique([name, parentId])
}

// A Product is one item you bought from a supplier invoice.
// Catalog details and purchase/invoice details are stored together.
// A fournisseur you buy from — managed on its own page, selected in forms.
model Supplier {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  phone    String?
  note     String?
  products Product[]
  invoices Invoice[]
}

// A facture from a fournisseur: number, date, place, total paid and a
// photo. Holds many product items; the app tracks how much of the
// total has been entered so far.
model Invoice {
  id          Int       @id @default(autoincrement())
  supplierId  Int
  supplier    Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  number      String // facture number or name
  date        DateTime  @default(now())
  place       String?
  totalAmount Float     @default(0) // total written on the facture
  imageUrl    String?
  createdAt   DateTime  @default(now())
  products    Product[]
}

model Product {
  id         Int       @id @default(autoincrement())
  name       String
  variant    String? // version of the same product: "Lemon", "Chocolate", …
  barcode    String? // EAN / UPC / Codabar — scanned or typed
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])

  // Purchase / invoice details
  supplierId Int?
  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  invoiceId  Int?
  invoice    Invoice?  @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  purchaseDate    DateTime  @default(now())
  packs           Int       @default(1) // how many packs bought
  unitsPerPack    Int       @default(1) // pieces per pack
  totalUnits      Int // packs * unitsPerPack — total pieces bought
  purchasePrice   Float // total price paid
  marginPercent   Float     @default(0) // desired selling margin %
  costPerUnit     Float // computed: purchasePrice / totalUnits
  sellPricePerUnit Float // computed: costPerUnit * (1 + margin/100)
  expirationDate  DateTime?
  invoiceImageUrl String?
  note            String?

  // Stock
  lowStockThreshold Int @default(10) // notify when remaining pieces <= this

  createdAt DateTime @default(now())
  sales     Sale[]
}

model Sale {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int // pieces sold
  unitPrice Float // price per piece at sale time
  total     Float // quantity * unitPrice
  saleDate  DateTime @default(now())
}
