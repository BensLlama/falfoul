# Local development: SQLite file (default)
DATABASE_URL="file:./dev.db"

# Production (Vercel + Turso): set these in Vercel's environment variables.
# When TURSO_DATABASE_URL is set, the app connects to Turso instead of
# the local file, and invoice photos are stored inline in the database.
# TURSO_DATABASE_URL="libsql://your-db-name-your-org.turso.io"
# TURSO_AUTH_TOKEN="…"
